{
  "name": "openable-dev",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint --tsconfig tsconfig.json",
    "lint:fix": "oxlint --fix --tsconfig tsconfig.json",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "next": "^16.2.2",
    "next-intl": "^4.8.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "oxlint --tsconfig tsconfig.json",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
